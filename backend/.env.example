# Copy to .env and fill in real values. Never commit .env.
#
# Configuration precedence (highest to lowest):
#   1. Environment variables (this file, or process.env)
#   2. backend/config.json (if it exists; see backend/config.example.json)
#   3. Built-in defaults in src/config.ts
#
# Both layers are optional but at least one MUST provide SESSION_SECRET.
# CONFIG_FILE env var lets you point at a custom JSON location.

# Database
POSTGRES_USER=crusade
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=crusade

# API
NODE_ENV=development
PORT=3000

# Sessions — MUST be a long random string in production
# Generate with: openssl rand -base64 48
SESSION_SECRET=replace-with-at-least-32-random-bytes-base64

# CORS — comma-separated origins of your frontend(s)
CORS_ORIGIN=http://localhost:5173

# Cookies — set COOKIE_SECURE=true in production behind HTTPS
COOKIE_SECURE=false
COOKIE_DOMAIN=

# When running locally outside Docker, point at the dockerised db:
DATABASE_URL=postgres://crusade:replace-with-strong-password@localhost:5432/crusade

# Admin: when set, supplying this passcode during /api/auth/register
# promotes the new account to site_admin. Leave unset to disable.
ADMIN_SIGNUP_PASSCODE=

# Path to a JSON config file (default: backend/config.json)
# CONFIG_FILE=/etc/crusade/config.json
