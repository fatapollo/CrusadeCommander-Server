# Copy to .env, fill in the values, then `docker compose up --build`.
# .env is gitignored. Never commit real secrets.

# ── Required ─────────────────────────────────────────────────────────
# Postgres password. Choose a strong random string.
POSTGRES_PASSWORD=replace-me-with-a-strong-password

# Session signing secret. Must be ≥ 32 chars in production.
# Generate with:  openssl rand -base64 48
SESSION_SECRET=replace-me-with-a-long-random-base64-string

# ── Optional ────────────────────────────────────────────────────────
# Host port the app listens on (default 3000)
PORT=3000

# Public URL — used for CORS and email-style links.
PUBLIC_URL=http://localhost:3000

# Set to "true" once you're behind HTTPS (sets Secure cookie flag).
COOKIE_SECURE=false

# Optional cookie domain (e.g. ".crusade.example.com")
COOKIE_DOMAIN=

# When set, users who supply this passcode on /api/auth/register become
# site admins. Leave blank to disable admin-by-signup entirely.
ADMIN_SIGNUP_PASSCODE=

# Postgres database / user names (rarely need to change)
POSTGRES_USER=crusade
POSTGRES_DB=crusade

# ── Unraid only (docker-compose.unraid.yml) ─────────────────────────
# Base path for the Postgres bind mount. Default suits most Unraid boxes.
APPDATA=/mnt/user/appdata
# Prebuilt image to run instead of building locally. Leave unset to build
# from source. After CI pushes to GHCR, set e.g.:
#   CRUSADE_IMAGE=ghcr.io/OWNER/crusade-commander:latest
CRUSADE_IMAGE=
