{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Vite dev, proxies /api to :3000)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend", "run", "dev"],
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "Full Stack (docker compose)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "--build"],
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "API (dev — tsx watch)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "backend", "run", "dev"],
      "port": 3000,
      "autoPort": true
    }
  ]
}
